// Loop invariants: basic invariants, multiple invariants, nested loops,
// invariants with pre/post contracts, and edge cases.

// Simple countdown with invariant proving result is non-negative.
fn countdown_inv(n: i32) -> i32
  pre { n >= 0; }
  post { r: r == 0; }
{
  var i: i32 = n;
  while (i > 0)
    invariant { i >= 0; }
  {
    i = i - 1;
  }
  return i;
}

// Accumulator loop with invariant tracking partial sum is non-negative.
fn sum_to_inv(n: i32) -> i32
  pre { n >= 0; }
  post { r: r >= 0; }
{
  var acc: i32 = 0;
  var i: i32 = 0;
  while (i < n)
    invariant { acc >= 0; i >= 0; i <= n; }
  {
    acc = acc + i;
    i = i + 1;
  }
  return acc;
}

// Multiple invariant expressions in a single invariant clause.
fn multi_invariant(n: i32) -> i32
  pre { n >= 0; }
  post { r: r >= 0; r <= n; }
{
  var x: i32 = 0;
  while (x < n)
    invariant { x >= 0; x <= n; }
  {
    x = x + 1;
  }
  return x;
}

// Loop that doubles a value, invariant says it stays positive.
fn double_loop(n: i32) -> i32
  pre { n >= 1; n < 100; }
  post { r: r >= n; }
{
  var x: i32 = n;
  var i: i32 = 0;
  while (i < 3)
    invariant { x >= n; i >= 0; i <= 3; }
  {
    x = x + n;
    i = i + 1;
  }
  return x;
}

// Invariant on a loop where the body never executes (condition false initially).
// With Hoare-logic reasoning, post-loop state is I ∧ ¬B.
// Here B is `false`, so ¬B is `true`, and we only get I: x >= 0.
// That suffices to prove r >= 0 but NOT r == 0.
fn never_runs_inv() -> i32
  post { r: r >= 0; }
{
  var x: i32 = 0;
  while (false)
    invariant { x >= 0; }
  {
    x = x + 1;
  }
  return x;
}

// A stronger invariant (x == 0) lets us prove the exact postcondition
// even though the loop never executes.
fn never_runs_strong_inv() -> i32
  post { r: r == 0; }
{
  var x: i32 = 0;
  while (false)
    invariant { x == 0; }
  {
    x = x + 1;
  }
  return x;
}

// Nested loops each with their own invariant.
fn nested_inv(rows: i32, cols: i32) -> i32
  pre { rows >= 0; cols >= 0; }
  post { r: r >= 0; }
{
  var total: i32 = 0;
  var r: i32 = 0;
  while (r < rows)
    invariant { total >= 0; r >= 0; r <= rows; }
  {
    var c: i32 = 0;
    while (c < cols)
      invariant { c >= 0; c <= cols; total >= 0; }
    {
      total = total + 1;
      c = c + 1;
    }
    r = r + 1;
  }
  return total;
}

// Invariant combined with function pre and post.
fn bounded_decrement(n: i32) -> i32
  pre { n >= 0; n < 1000; }
  post { r: r == 0; }
{
  var x: i32 = n;
  while (x > 0)
    invariant { x >= 0; }
  {
    x = x - 1;
  }
  return x;
}

// Loop with invariant on two variables.
fn swap_track(a: i32, b: i32) -> i32
  pre { a >= 0; b >= 0; }
  post { r: r >= 0; }
{
  var x: i32 = a;
  var y: i32 = b;
  while (x > 0)
    invariant { x >= 0; y >= 0; }
  {
    y = y + 1;
    x = x - 1;
  }
  return y;
}

// Simple identity loop: x stays the same.
fn identity_loop(n: i32) -> i32
  pre { n >= 0; }
  post { r: r == n; }
{
  var x: i32 = n;
  var i: i32 = 0;
  while (i < 10)
    invariant { x == n; i >= 0; i <= 10; }
  {
    i = i + 1;
  }
  return x;
}

// Loop with invariant that the counter stays bounded.
fn bounded_counter() -> i32
  post { r: r == 5; }
{
  var i: i32 = 0;
  while (i < 5)
    invariant { i >= 0; i <= 5; }
  {
    i = i + 1;
  }
  return i;
}

// Void function with loop invariant (no return value contract, just exercises parsing).
fn void_with_invariant(n: i32)
  pre { n >= 0; }
{
  var i: i32 = 0;
  while (i < n)
    invariant { i >= 0; i <= n; }
  {
    i = i + 1;
  }
}

// Sequential loops each with their own invariant.
fn two_loops_inv(a: i32, b: i32) -> i32
  pre { a >= 0; b >= 0; }
  post { r: r == 0; }
{
  var x: i32 = a;
  while (x > 0)
    invariant { x >= 0; }
  {
    x = x - 1;
  }
  var y: i32 = b;
  while (y > 0)
    invariant { y >= 0; x == 0; }
  {
    y = y - 1;
  }
  return x + y;
}
